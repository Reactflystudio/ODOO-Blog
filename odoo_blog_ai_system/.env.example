# ==============================================================================
# ODOO BLOG AI SYSTEM — Configuração de Ambiente
# Copie para .env e preencha com seus valores
# ==============================================================================

# ── LLM PROVIDERS ─────────────────────────────
# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# Google Gemini
GOOGLE_AI_API_KEY=your-gemini-key-here
GOOGLE_AI_MODEL=gemini-2.0-flash

# Anthropic (opcional)
ANTHROPIC_API_KEY=your-anthropic-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Provider padrão: openai, gemini ou anthropic
DEFAULT_LLM_PROVIDER=openai

# ── ODOO ────────────────────────────────────────
ODOO_URL=https://seu-odoo.com
ODOO_DB=seu-banco
ODOO_USERNAME=seu-usuario
ODOO_PASSWORD=sua-senha
ODOO_BLOG_ID=1

# ── IMAGENS ─────────────────────────────────────
# Provedor: dalle ou unsplash
IMAGE_PROVIDER=dalle

# Unsplash (fallback gratuito)
UNSPLASH_API_KEY=your-unsplash-key-here

# Pexels (fallback alternativo)
PEXELS_API_KEY=your-pexels-key-here

# ── SCRAPING & TRENDS ───────────────────────────
# NewsAPI (opcional — https://newsapi.org)
NEWS_API_KEY=your-newsapi-key-here

# Reddit API (opcional)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── CONTEÚDO (DEFAULTS) ────────────────────────
DEFAULT_LANGUAGE=pt-br
DEFAULT_TONE=professional
DEFAULT_DEPTH=intermediate
DEFAULT_AUTHOR_NAME=Equipe Blog
MIN_WORDS=1500
MAX_WORDS=2500

# ── SEO ──────────────────────────────────────────
KEYWORD_DENSITY_MIN=0.01
KEYWORD_DENSITY_MAX=0.02
KEYWORD_STUFFING_THRESHOLD=0.03

# ── SISTEMA ──────────────────────────────────────
MAX_CONCURRENT_LLM_CALLS=5
ARTICLES_PER_DAY=5
SCHEDULE_START_TIME=08:00
SCHEDULE_END_TIME=18:00
LOG_LEVEL=INFO
